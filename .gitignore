.DS_Store
.obsidian/
.claude/plans/
.claude/settings.json
.claude/settings.local.json

# Node.js dependencies (installed by `npm install` for the wizard)
node_modules/

# Exports — each generated system is independent.
exports/*
!exports/.gitkeep

# Personal config and resolved config — gitignored
config/config.user.toml
config/.resolved.toml

# Manifest is generated at install time
config/manifest.yaml

# Context ledger and memory — content excluded, directories tracked
context-ledger/*
!context-ledger/.gitkeep
memory/*
!memory/.gitkeep

# Welcome marker (per-machine)
memory/welcome-shown.md
